# App Environment
ENVIRONMENT=development
JWT_SECRET_KEY=generate_a_secure_secret_key_here

# Database Configuration (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=forest_intel
MYSQL_USER=fis_user
MYSQL_PASSWORD=fis_password

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Google Earth Engine Configuration
GEE_SERVICE_ACCOUNT_EMAIL=your-service-account-email@your-project-id.iam.gserviceaccount.com
GEE_SERVICE_ACCOUNT_KEY_PATH=backend/secrets/gee-service-account.json

# Google Cloud Storage Configuration
# GCS requires billing. Keep GCS_BUCKET_NAME=not-configured for local development.
# To enable cloud export: set STORAGE_BACKEND=gcs and provide a real bucket name.
STORAGE_BACKEND=local
GCS_BUCKET_NAME=not-configured

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
